      "type": "text",
      "x": 30,
      "y": 345,
      "width": 500,
      "height": 40,
      "text": "offset += 1, 3, 6, 10, 15 ...  (triangular numbers)\nVisits ALL groups when num_groups = 2^M",
      "fontSize": 14,
      "fontFamily": 1,
      "strokeColor": "#94a3b8"
    },
    {
      "id": "formula",
      "type": "text",
      "x": 30,
      "y": 400,
      "width": 500,
      "height": 20,
      "text": "offset(i) = i × (i + 1) / 2     (mod num_groups)",
      "fontSize": 16,
      "fontFamily": 3,
      "strokeColor": "#a78bfa"
    }
