      "x": 90, "y": 240, "width": 50, "height": 18,
      "text": "Key", "fontSize": 16, "fontFamily": 3, "strokeColor": "#ffffff"
    },
    {
      "id": "val-ptr",
      "type": "rectangle",
      "x": 200, "y": 230, "width": 80, "height": 38,
      "strokeColor": "#fbbf24", "backgroundColor": "#1e293b", "fillStyle": "solid", "roundness": {"type": 3}
    },
    {
      "id": "val-ptr-t",
      "type": "text",
      "x": 220, "y": 240, "width": 40, "height": 18,
      "text": "*ptr", "fontSize": 14, "fontFamily": 3, "strokeColor": "#fbbf24"
