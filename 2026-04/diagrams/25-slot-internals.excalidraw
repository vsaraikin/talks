      "type": "arrow",
      "x": 285, "y": 249, "width": 100, "height": 0,
      "strokeColor": "#fbbf24", "points": [[0, 0], [100, 0]]
    },
    {
      "id": "heap-val",
      "type": "rectangle",
      "x": 400, "y": 220, "width": 200, "height": 60,
      "strokeColor": "#f9a8d4", "backgroundColor": "#9d174d", "fillStyle": "solid", "roundness": {"type": 3}
    },
    {
      "id": "heap-val-t",
      "type": "text",
      "x": 430, "y": 235, "width": 140, "height": 30,
      "text": "Value (heap)\n> 128 bytes", "fontSize": 14, "fontFamily": 3, "strokeColor": "#ffffff"
    },
    {
      "id": "old-compare",
      "type": "text",
      "x": 30, "y": 310, "width": 500, "height": 40,
      "text": "Old map: keys[] and values[] in separate arrays\nSwiss:   [K|V] [K|V] [K|V] ... together in slot",
      "fontSize": 14, "fontFamily": 3, "strokeColor": "#94a3b8"
    }
  ],
  "appState": {
    "theme": "dark",
