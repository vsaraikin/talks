      "x": 200, "y": 105, "width": 160, "height": 38,
      "strokeColor": "#f9a8d4", "backgroundColor": "#9d174d", "fillStyle": "solid", "roundness": {"type": 3}
    },
    {
      "id": "val-inline-t",
      "type": "text",
      "x": 250, "y": 115, "width": 60, "height": 18,
      "text": "Value", "fontSize": 16, "fontFamily": 3, "strokeColor": "#ffffff"
    },
    {
      "id": "inline-note",
      "type": "text",
      "x": 400, "y": 110, "width": 250, "height": 16,
      "text": "← same cache line, great locality",
      "fontSize": 13, "fontFamily": 1, "strokeColor": "#34d399"
    },
    {
      "id": "ptr-label",
      "type": "text",
      "x": 30, "y": 185, "width": 350, "height": 22,
      "text": "Value > 128 bytes: pointer in slot",
      "fontSize": 17, "fontFamily": 3, "strokeColor": "#fbbf24"
    },
    {
      "id": "slot-ptr",
      "type": "rectangle",
      "x": 30, "y": 220, "width": 350, "height": 60,
      "strokeColor": "#94a3b8", "backgroundColor": "#1e293b", "fillStyle": "solid", "roundness": {"type": 3}
    },
    {
      "id": "key-ptr",
      "type": "rectangle",
      "x": 45, "y": 230, "width": 140, "height": 38,
      "strokeColor": "#60a5fa", "backgroundColor": "#1e40af", "fillStyle": "solid", "roundness": {"type": 3}
    },
    {
      "id": "key-ptr-t",
