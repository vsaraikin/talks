{
  "type": "excalidraw",
  "version": 2,
  "source": "claude",
  "elements": [
    {
      "id": "title",
      "type": "text",
      "x": 30, "y": 15, "width": 300, "height": 24,
      "text": "Slot layout: K + V together",
      "fontSize": 20, "fontFamily": 3, "strokeColor": "#fef3c7"
    },
    {
      "id": "inline-label",
      "type": "text",
      "x": 30, "y": 60, "width": 300, "height": 22,
      "text": "Value ≤ 128 bytes: inline",
      "fontSize": 17, "fontFamily": 3, "strokeColor": "#5eead4"
    },
    {
      "id": "slot-inline",
      "type": "rectangle",
      "x": 30, "y": 95, "width": 350, "height": 60,
      "strokeColor": "#94a3b8", "backgroundColor": "#1e293b", "fillStyle": "solid", "roundness": {"type": 3}
    },
    {
      "id": "key-inline",
      "type": "rectangle",
      "x": 45, "y": 105, "width": 140, "height": 38,
      "strokeColor": "#60a5fa", "backgroundColor": "#1e40af", "fillStyle": "solid", "roundness": {"type": 3}
    },
    {
      "id": "key-inline-t",
      "type": "text",
