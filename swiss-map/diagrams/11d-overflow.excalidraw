    {
      "id": "warning",
      "type": "text",
      "x": 480,
      "y": 260,
      "width": 380,
      "height": 60,
      "text": "⚠ Each overflow = new heap alloc\n  Random address = CPU cache miss\n  Chain grows = O(n) worst case",
      "fontSize": 15,
      "fontFamily": 1,
      "strokeColor": "#fecaca"
    }
  ],
  "appState": {
    "theme": "dark",
