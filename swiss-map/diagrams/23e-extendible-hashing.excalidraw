    {
      "id": "ld-explain",
      "type": "text",
      "x": 30, "y": 245, "width": 750, "height": 80,
      "text": "local_depth  = snapshot of global_depth when table was created\n\nif local_depth < global_depth\n  → table has spare directory entries → no directory growth needed",
