    {
      "id": "vs-title",
      "type": "text",
      "x": 45,
      "y": 325,
      "width": 300,
      "height": 18,
      "text": "Swiss Table solution:",
      "fontSize": 15,
      "fontFamily": 3,
      "strokeColor": "#5eead4"
    },
    {
      "id": "vs-text",
      "type": "text",
      "x": 45,
      "y": 348,
      "width": 750,
      "height": 28,
      "text": "1 SIMD instruction → compare ALL 8 at once → no window for eviction",
      "fontSize": 18,
      "fontFamily": 1,
      "strokeColor": "#ffffff"
    }
  ],
  "appState": {
    "theme": "dark",
