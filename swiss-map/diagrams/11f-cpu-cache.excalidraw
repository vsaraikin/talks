      "height": 40,
      "strokeColor": "#94a3b8",
      "backgroundColor": "#1e293b",
      "fillStyle": "solid"
    },
    {
      "id": "step3-text",
      "type": "text",
      "x": 40,
      "y": 243,
      "width": 220,
      "height": 20,
      "text": "3. Compare k2 == key?",
      "fontSize": 15,
      "fontFamily": 3,
      "strokeColor": "#e2e8f0"
    },
    {
      "id": "dots",
      "type": "text",
      "x": 100,
      "y": 285,
      "width": 100,
      "height": 20,
      "text": "... × 8",
      "fontSize": 16,
      "fontFamily": 3,
      "strokeColor": "#94a3b8"
    },
    {
      "id": "vs-box",
      "type": "rectangle",
      "x": 30,
      "y": 320,
      "width": 780,
