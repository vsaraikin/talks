{
  "type": "excalidraw",
  "version": 2,
  "source": "claude",
  "elements": [
    {
      "id": "title",
      "type": "text",
      "x": 30,
      "y": 15,
      "width": 400,
      "height": 26,
      "text": "Sequential Compare + Cache Lines",
      "fontSize": 20,
      "fontFamily": 3,
      "strokeColor": "#ffffff"
    },
    {
      "id": "cache-line-box",
      "type": "rectangle",
      "x": 30,
      "y": 55,
      "width": 560,
      "height": 50,
      "strokeColor": "#5eead4",
      "backgroundColor": "#042f2e",
      "fillStyle": "solid",
      "roundness": {"type": 3}
    },
    {
      "id": "cache-line-label",
      "type": "text",
      "x": 40,
      "y": 58,
      "width": 200,
      "height": 16,
      "text": "CPU Cache Line (64 bytes):",
      "fontSize": 12,
      "fontFamily": 3,
      "strokeColor": "#94a3b8"
    },
    {
      "id": "cache-line-content",
      "type": "text",
      "x": 40,
      "y": 76,
      "width": 540,
      "height": 20,
      "text": "[k0] [k1] [k2] [k3] [k4] [k5] [k6] [k7]  ← all loaded at once!",
      "fontSize": 15,
      "fontFamily": 3,
      "strokeColor": "#a7f3d0"
    },
    {
      "id": "step1-box",
      "type": "rectangle",
      "x": 30,
      "y": 125,
      "width": 240,
      "height": 40,
      "strokeColor": "#5eead4",
      "backgroundColor": "#042f2e",
      "fillStyle": "solid"
    },
    {
      "id": "step1-text",
      "type": "text",
      "x": 40,
      "y": 133,
      "width": 220,
      "height": 20,
      "text": "1. Compare k0 == key?",
      "fontSize": 15,
      "fontFamily": 3,
      "strokeColor": "#ffffff"
    },
    {
      "id": "step1-result",
      "type": "text",
      "x": 290,
      "y": 133,
      "width": 60,
      "height": 20,
      "text": "✗ no",
      "fontSize": 15,
      "fontFamily": 3,
      "strokeColor": "#fca5a5"
    },
    {
      "id": "interrupt-box",
      "type": "rectangle",
      "x": 390,
      "y": 120,
      "width": 420,
      "height": 55,
      "strokeColor": "#f87171",
      "backgroundColor": "#450a0a",
      "fillStyle": "solid",
      "roundness": {"type": 3},
      "strokeStyle": "dashed"
    },
    {
      "id": "interrupt-text",
      "type": "text",
      "x": 405,
      "y": 125,
      "width": 400,
      "height": 40,
      "text": "💥 OS context switch!\nAnother process uses CPU registers.\nYour cache line gets EVICTED.",
      "fontSize": 13,
      "fontFamily": 1,
      "strokeColor": "#fecaca"
    },
    {
      "id": "step2-box",
      "type": "rectangle",
      "x": 30,
      "y": 185,
      "width": 240,
      "height": 40,
      "strokeColor": "#fbbf24",
      "backgroundColor": "#422006",
      "fillStyle": "solid"
    },
    {
      "id": "step2-text",
      "type": "text",
      "x": 40,
      "y": 193,
      "width": 220,
      "height": 20,
      "text": "2. Compare k1 == key?",
      "fontSize": 15,
      "fontFamily": 3,
      "strokeColor": "#fef3c7"
    },
    {
      "id": "step2-reload",
      "type": "text",
      "x": 290,
      "y": 193,
      "width": 300,
      "height": 20,
      "text": "← must RELOAD from RAM (~100 cycles)",
      "fontSize": 14,
      "fontFamily": 3,
      "strokeColor": "#fca5a5"
    },
    {
      "id": "step3-box",
      "type": "rectangle",
      "x": 30,
      "y": 235,
